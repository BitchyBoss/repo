<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.leosystems"
       name="LeoSystems Repo"
       version="2.0.0"
       provider-name="LeoSystems">

  <extension point="xbmc.addon.repository">
    <dir>
      <info compressed="false">https://leobitchy.github.io/leosystems-repo/addons.xml</info>
      <checksum>https://leobitchy.github.io/leosystems-repo/addons.xml.md5</checksum>
      <datadir zip="true">https://leobitchy.github.io/leosystems-repo/</datadir>
    </dir>
